<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TarotAi" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Splash Screen Theme - Fondo oscuro simple sin imagen -->
    <style name="Theme.App.Starting" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Fondo oscuro igual al de la app -->
        <item name="android:windowBackground">@color/splash_background</item>
        <!-- Sin Action Bar -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <!-- Status bar oscura -->
        <item name="android:statusBarColor">@color/splash_background</item>
        <!-- SIN imagen en el splash del sistema -->
    </style>
</resources>