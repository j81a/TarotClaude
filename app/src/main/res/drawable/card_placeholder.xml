<?xml version="1.0" encoding="utf-8"?>
<!-- Placeholder temporal para cartas del tarot -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Fondo con gradiente -->
    <gradient
        android:angle="135"
        android:startColor="#6B46C1"
        android:centerColor="#805AD5"
        android:endColor="#9F7AEA"
        android:type="linear" />

    <!-- Borde redondeado -->
    <corners android:radius="8dp" />

    <!-- Borde -->
    <stroke
        android:width="2dp"
        android:color="#D6BCFA" />

    <!-- Tamaño -->
    <size
        android:width="200dp"
        android:height="350dp" />
</shape>
